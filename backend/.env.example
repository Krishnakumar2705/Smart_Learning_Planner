PORT=5000
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/smart-learning-planner

# Clerk Backend Secret Key — from https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx

# Google Gemini API Key — from https://aistudio.google.com
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# JWT Secret (used for any custom JWT signing)
JWT_SECRET=change_this_to_a_long_random_string

# Your deployed frontend URL (for CORS) — e.g. https://smart-learning-planner-nu.vercel.app
FRONTEND_URL=https://your-vercel-app.vercel.app

# Email OTP Configuration (Gmail)
# Use a Gmail App Password — NOT your real Gmail password.
# Enable App Passwords: Google Account → Security → 2-Step Verification → App Passwords
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password
